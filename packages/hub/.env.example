# Network mode: 'mainnet' | 'sandbox'
# mainnet: Base (chain 8453), USDC, wss://clearnet.yellow.com/ws
# sandbox: Sepolia (chain 11155111), ytest.usd, wss://clearnet-sandbox.yellow.com/ws
NETWORK_MODE=sandbox

# Clearnode WebSocket URL (overrides NETWORK_MODE default)
# Mainnet: wss://clearnet.yellow.com/ws
# Sandbox: wss://clearnet-sandbox.yellow.com/ws
CLEARNODE_URL=wss://clearnet-sandbox.yellow.com/ws

# Market Maker private key (MUST be funded with USDC on Base for mainnet)
MM_PRIVATE_KEY=0x...

# Application name registered with Clearnode
APPLICATION_NAME=pulse-play

# Faucet URL (sandbox only, ignored on mainnet)
FAUCET_URL=https://clearnet-sandbox.yellow.com/faucet/requestTokens

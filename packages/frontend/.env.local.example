# Network mode: 'mainnet' | 'sandbox'
# mainnet: Base (chain 8453), USDC, wss://clearnet.yellow.com/ws
# sandbox: Sepolia (chain 11155111), ytest.usd, wss://clearnet-sandbox.yellow.com/ws
NEXT_PUBLIC_NETWORK_MODE=sandbox

# Hub API URLs
NEXT_PUBLIC_HUB_REST_URL=http://localhost:3001
NEXT_PUBLIC_HUB_WS_URL=ws://localhost:3001/ws

# Wallet connection mode: 'metamask' | 'private-key'
# - metamask: Connect via browser MetaMask extension
# - private-key: Use NEXT_PUBLIC_PRIVATE_KEY (default)
NEXT_PUBLIC_WALLET_MODE=private-key

# Test wallet private key (for private-key mode)
# This should be a test wallet with no real funds
# Only used when NEXT_PUBLIC_WALLET_MODE=private-key
NEXT_PUBLIC_PRIVATE_KEY=0x...

# Clearnode WebSocket URL (overrides NETWORK_MODE default)
# NEXT_PUBLIC_CLEARNODE_URL=wss://clearnet-sandbox.yellow.com/ws

# Market Maker wallet address (counterparty for app sessions)
NEXT_PUBLIC_MM_ADDRESS=0x...
